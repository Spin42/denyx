From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: AUTHOR <EMAIL>
Date: Fri, 22 May 2026 00:00:00 +0000
Subject: [PATCH] wifi: wcn36xx: abort on HAL errors in join and post-assoc
 paths

When roaming between BSSIDs on the same SSID a failed firmware
handshake during the join phase can drive the WCNSS coprocessor into a
fatal state that requires a full remoteproc reload to recover.

The sequence observed on WCN3620 (Fairphone 2):

1. BSS_CHANGED_BSSID fires for the first BSSID.  hal_join and
   hal_config_bss (pre-assoc, no STA) both return -EIO (firmware HAL
   status 5).  The driver logs the errors but discards the return
   values and continues.  vif_priv->bss_index remains at
   WCN36XX_HAL_BSS_INVALID_IDX (0xFF).

2. 802.11 auth and association frames succeed at the hardware level
   (the radio can still exchange frames even with a broken HAL state);
   mac80211 fires BSS_CHANGED_ASSOC with assoc=true.

3. The driver calls hal_config_bss (post-assoc, with STA) while the
   firmware BSS table is in the inconsistent state from step 1.  The
   WCNSS coprocessor asserts:

     halStaTable.c:halBssTableGetBssInfo: Invalid BSSIndex 255

   After this panic every subsequent SMD command times out (~10 s
   each), wlan0 disappears, and the driver cannot recover without a
   full remoteproc reload.

The same firmware panic recurs on the next driver load because the
coprocessor is still in the faulted state; IRQ controller retains a
stale mapping on hwirq-177 and the last wcn36xx_smd_add_sta_self call
in probe fails with -ENXIO.

Fix this in two complementary layers:

(a) Propagate hal_join and hal_config_bss (pre-assoc) errors in the
    BSS_CHANGED_BSSID handler.  On failure reset is_joining and abort.
    Because bss_index stays at WCN36XX_HAL_BSS_INVALID_IDX the guard
    in (b) will catch any subsequent association attempt and signal a
    clean disconnection to mac80211.

(b) At the start of the BSS_CHANGED_ASSOC assoc=true path, check
    whether bss_index is still WCN36XX_HAL_BSS_INVALID_IDX, which
    indicates that pre-assoc hal_config_bss never assigned a firmware
    BSS slot.  If so, flag connection_loss and abort rather than
    sending hal_config_bss to a firmware whose BSS table is known to
    be corrupt.  Apply the same treatment to failures in the post-assoc
    hal_config_bss and hal_config_sta calls, which were also
    previously ignored.  ieee80211_connection_loss() is deferred until
    after conf_mutex is released to avoid re-entrant locking.

This does not address the stale BSS slot that can accumulate in the
firmware when BSS_CHANGED_BSSID clears bss_index before the previous
BSS is deleted; that is a pre-existing accounting issue independent of
this crash path.

Reported-by: Alex <alex@example.com>
Signed-off-by: AUTHOR <EMAIL>
---
 drivers/net/wireless/ath/wcn36xx/main.c | 75 ++++++++++++++++++++----
 1 file changed, 63 insertions(+), 12 deletions(-)

diff --git a/drivers/net/wireless/ath/wcn36xx/main.c b/drivers/net/wireless/ath/wcn36xx/main.c
index XXXXXXX..YYYYYYY 100644
--- a/drivers/net/wireless/ath/wcn36xx/main.c
+++ b/drivers/net/wireless/ath/wcn36xx/main.c
@@ -801,10 +801,12 @@ static void wcn36xx_bss_info_changed(struct ieee80211_hw *hw,
 {
 	struct wcn36xx *wcn = hw->priv;
 	struct sk_buff *skb = NULL;
+	bool connection_loss = false;
 	u16 tim_off, tim_len;
 	enum wcn36xx_hal_link_state link_state;
 	struct wcn36xx_vif *vif_priv = wcn36xx_vif_to_priv(vif);
+	int ret;

 	wcn36xx_dbg(WCN36XX_DBG_MAC, "mac bss info changed vif %p changed 0x%llx\n",
 		    vif, changed);
@@ -823,11 +825,27 @@ static void wcn36xx_bss_info_changed(struct ieee80211_hw *hw,
 		if (!is_zero_ether_addr(bss_conf->bssid)) {
 			vif_priv->is_joining = true;
 			vif_priv->bss_index = WCN36XX_HAL_BSS_INVALID_IDX;
 			wcn36xx_smd_set_link_st(wcn, bss_conf->bssid, vif->addr,
 						WCN36XX_HAL_LINK_PREASSOC_STATE);
-			wcn36xx_smd_join(wcn, bss_conf->bssid,
-					 vif->addr, WCN36XX_HW_CHANNEL(wcn));
-			wcn36xx_smd_config_bss(wcn, vif, NULL,
-					       bss_conf->bssid, false);
+			ret = wcn36xx_smd_join(wcn, bss_conf->bssid,
+					       vif->addr, WCN36XX_HW_CHANNEL(wcn));
+			if (ret) {
+				wcn36xx_err("failed to join BSS %pM: %d\n",
+					    bss_conf->bssid, ret);
+				vif_priv->is_joining = false;
+				goto out;
+			}
+			ret = wcn36xx_smd_config_bss(wcn, vif, NULL,
+						     bss_conf->bssid, false);
+			if (ret) {
+				wcn36xx_err("failed to config BSS %pM: %d\n",
+					    bss_conf->bssid, ret);
+				vif_priv->is_joining = false;
+				goto out;
+			}
 		} else {
 			vif_priv->is_joining = false;
 			wcn36xx_smd_delete_bss(wcn, vif);
@@ -857,6 +875,15 @@ static void wcn36xx_bss_info_changed(struct ieee80211_hw *hw,

 			vif_priv->sta_assoc = true;

+			if (vif_priv->bss_index == WCN36XX_HAL_BSS_INVALID_IDX) {
+				wcn36xx_err("pre-assoc config_bss failed for %pM, dropping association\n",
+					    bss_conf->bssid);
+				vif_priv->sta_assoc = false;
+				connection_loss = true;
+				goto out;
+			}
+
 			/*
 			 * Holding conf_mutex ensures mutal exclusion with
 			 * wcn36xx_sta_remove() and as such ensures that sta
@@ -876,13 +903,33 @@ static void wcn36xx_bss_info_changed(struct ieee80211_hw *hw,
 			wcn36xx_smd_set_link_st(wcn, bss_conf->bssid,
 				vif->addr,
 				WCN36XX_HAL_LINK_POSTASSOC_STATE);
-			wcn36xx_smd_config_bss(wcn, vif, sta,
-					       bss_conf->bssid,
-					       true);
+			ret = wcn36xx_smd_config_bss(wcn, vif, sta,
+						     bss_conf->bssid, true);
+			if (ret) {
+				wcn36xx_err("failed to config BSS post-assoc %pM: %d\n",
+					    bss_conf->bssid, ret);
+				vif_priv->sta_assoc = false;
+				connection_loss = true;
+				goto out;
+			}
 			sta_priv->aid = vif->cfg.aid;
 			/*
 			 * config_sta must be called from  because this is the
 			 * place where AID is available.
 			 */
-			wcn36xx_smd_config_sta(wcn, vif, sta);
+			ret = wcn36xx_smd_config_sta(wcn, vif, sta);
+			if (ret) {
+				wcn36xx_err("failed to config STA for %pM: %d\n",
+					    bss_conf->bssid, ret);
+				vif_priv->sta_assoc = false;
+				connection_loss = true;
+				goto out;
+			}
 			if (vif->type == NL80211_IFTYPE_STATION)
 				wcn36xx_smd_add_beacon_filter(wcn, vif);
 			wcn36xx_enable_keep_alive_null_packet(wcn, vif);
@@ -958,6 +1005,8 @@ static void wcn36xx_bss_info_changed(struct ieee80211_hw *hw,
 	}
 out:

-	mutex_unlock(&wcn->conf_mutex);
+	mutex_unlock(&wcn->conf_mutex);
+	if (connection_loss)
+		ieee80211_connection_loss(vif);
 }
--
2.39.0
